+	ctxKey := "ThisIsAContextKey"
+
+	app := fiber.New()
+	app.Use(New(Config{
+		Generator: func() string {
+			return reqId
+		},
+		ContextKey: ctxKey,
+	}))
+
+	var ctxVal string
+
+	app.Use(func (c *fiber.Ctx) error {
+		ctxVal = c.Locals(ctxKey).(string)
+		return c.Next()
+	})
+
