diff --git a/tests/test_pretty.py b/tests/test_pretty.py
index cf838db206..938f216bb0 100644
--- a/tests/test_pretty.py
+++ b/tests/test_pretty.py
@@ -250,3 +250,15 @@ def __repr__(self):
     result = pretty_repr(d2, expand_all=True)
     print(repr(result))
     assert result == "FOO"
+
+
+def test_lying_attribute():
+    """Test getattr doesn't break rich repr protocol"""
+
+    class Foo:
+        def __getattr__(self, attr):
+            return "foo"
+
+    foo = Foo()
+    result = pretty_repr(foo)
+    assert "Foo" in result
